{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "RegistrationNumber": {
      "type": "string",
      "minLength": 4,
      "maxLength": 8
    },
    "VIN": {
      "type": "string",
      "minLength": 17,
      "maxLength": 17
    },
    "FirstRegistrationDate": {
      "type": "string",
      "pattern": "^\\d{2}\\.\\d{2}\\.\\d{4}$" 
    }
  },
  "required": [
    "RegistrationNumber",
    "VIN",
    "FirstRegistrationDate"
  ],
  "additionalProperties": false
}